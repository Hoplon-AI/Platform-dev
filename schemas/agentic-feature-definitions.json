    "category_c_docb_planb": {
      "category": "C",
      "description": "PlanB/DocB portfolio columns (high-value property fields) - Required DocB outputs when present in documents",
      "features": {
        "docb_required_fields": {
          "description": "Core DocB/PlanB fields from property-schema.json - High-value property details",
          "fields": {
            "claddingType": {
              "type": "string",
              "description": "Type of cladding material",
              "priority": "high",
              "source": "property-schema.json",
              "extraction_hints": [
                "Look for explicit cladding material mentions",
                "Common types: ACM, HPL, timber, composite, etc.",
                "May be in external wall system descriptions"
              ]
            },
            "ewsStatus": {
              "type": "string",
              "description": "External Wall System (EWS) status",
              "priority": "high",
              "source": "property-schema.json",
              "extraction_hints": [
                "Look for EWS1 report references",
                "EWS status ratings (A1, A2, A3, B1, B2)",
                "External wall system assessment outcomes"
              ]
            },
            "fireRiskManagementSummary": {
              "type": "string",
              "description": "Summary of fire risk management measures",
              "priority": "high",
              "source": "property-schema.json",
              "extraction_hints": [
                "Look for fire risk management sections",
                "Summary statements about fire safety measures",
                "May be in executive summaries or conclusions"
              ]
            },
            "docBRef": {
              "type": "string",
              "description": "Document B reference (high value properties)",
              "priority": "high",
              "source": "property-schema.json",
              "extraction_hints": [
                "Look for 'Doc B' or 'Document B' references",
                "May appear in headers, footers, or reference sections",
                "Often includes reference numbers or codes"
              ]
            }
          }
        },
        "docb_optional_context_fields": {
          "description": "Optional related context fields if they appear in the same source docs",
          "fields": {
            "fireProtection": {
              "type": "string",
              "description": "Fire protection measures",
              "priority": "medium",
              "source": "property-schema.json",
              "extraction_hints": [
                "Look for fire protection system descriptions",
                "May overlap with fire_safety_measures extraction"
              ]
            },
            "alarms": {
              "type": "string",
              "description": "Alarm system type and classification",
              "priority": "medium",
              "source": "property-schema.json",
              "extraction_hints": [
                "Look for alarm system specifications",
                "May overlap with fire_alarm_systems extraction"
              ]
            },
            "evacuationStrategy": {
              "type": "string",
              "description": "Evacuation strategy for the property",
              "priority": "medium",
              "source": "property-schema.json",
              "extraction_hints": [
                "Look for evacuation strategy descriptions",
                "May overlap with evacuation_strategy extraction from Category A"
              ]
            },
            "floorsAboveGround": {
              "type": "integer",
              "description": "Number of floors above ground",
              "minimum": 0,
              "priority": "medium",
              "source": "property-schema.json",
              "extraction_hints": [
                "Look for storey counts or floor numbers",
                "May overlap with number_of_storeys from high_rise_indicators"
              ]
            },
            "floorsBelowGround": {
              "type": "integer",
              "description": "Number of floors below ground",
              "minimum": 0,
              "priority": "medium",
              "source": "property-schema.json",
              "extraction_hints": [
