                "May be in building description sections"
              ]
            }
          }
        }
      }
    }
  },
  "extraction_guidance": {
    "confidence_scoring": {
      "explicit_mention": {
        "range": [0.9, 1.0],
        "description": "Field explicitly stated in document"
      },
      "strong_inference": {
        "range": [0.7, 0.9],
        "description": "Clear context suggests value"
      },
      "weak_inference": {
        "range": [0.5, 0.7],
        "description": "Some context but uncertain"
      },
      "not_found": {
        "value": null,
        "description": "No evidence found"
      }
    },
    "extraction_priority": {
      "high": "Extract with highest priority - critical for ML/UI",
      "medium": "Extract if present - useful for context",
      "low": "Extract if easily found - nice to have"
    },
    "evidence_requirements": {
      "required": true,
      "description": "Every extracted field should include: value, confidence (0-1), evidence (quoted snippet(s) and/or page refs when available)"
    }
  }
}
